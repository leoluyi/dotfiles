<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.leoluyi.espanso-watchdog</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/leoluyi/.local/bin/espanso-ensure-running</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>StandardOutPath</key>
    <string>/Users/leoluyi/.local/state/espanso-watchdog/launchd.out</string>
    <key>StandardErrorPath</key>
    <string>/Users/leoluyi/.local/state/espanso-watchdog/launchd.err</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
