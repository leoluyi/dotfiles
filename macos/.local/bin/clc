#!/bin/sh
# clc - Cross-platform (cl)ipboard (c)opy
# < https://github.com/thezeroalpha/dotfiles/blob/master/scripts/clc >

usage() {
  cat <<EOF
Usage: ${0##*/} [file]

Copy text to the system clipboard (macOS, Linux, or Windows).

  <command> | ${0##*/}    copy stdin to the clipboard
  ${0##*/} <file>         copy a file's contents to the clipboard

Options:
  -h, --help    Show this help and exit
EOF
}

case "$1" in
  -h|--help) usage; exit 0 ;;
esac

file=$1
os=$(uname -s | tr '[:upper:]' '[:lower:]')
case "$os" in
  linux*)
    if command -v xclip 1>/dev/null 2>&1; then
      if [ -z "$file" ]; then
        xclip -in -selection clipboard
      else
        xclip -in -selection clipboard "$file"
      fi
    elif command -v xsel 1>/dev/null 2>&1; then
      if [ -z "$file" ]; then
        xsel --clipboard --input
      else
        xsel --clipboard --input < "$file"
      fi
    else
      printf "xclip/xsel not installed\n"
    fi
    ;;
  darwin*)
    if [ -z "$file" ]; then
      pbcopy
    else
      pbcopy < "$file"
    fi
    ;;
  msys*|cygwin*|mingw*|nt|win*)
    if [ -z "$file" ]; then
      cat > /dev/clipboard
    else
      cat "$file" > /dev/clipboard
    fi
    ;;
  *)
    printf "clc: Platform %s not supported.\n" "$os" >&2
    exit 1
    ;;
esac
