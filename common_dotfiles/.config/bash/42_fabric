# vim: ft=sh:
# shellcheck shell=bash
# fabric-ai shell integration (https://github.com/danielmiessler/fabric)

command -v fabric-ai >/dev/null || return 0

# The Homebrew binary is named `fabric-ai`, but fabric uses its own invocation
# name (argv[0]) as a pattern shortcut: any name other than `fabric` is treated
# as a pattern to load, so a bare `fabric-ai` fails with "pattern 'fabric-ai'
# not found". Re-exec under argv[0]=fabric (in a subshell so the interactive
# shell is not replaced) to restore the upstream-intended behavior.
fabric() { ( exec -a fabric fabric-ai "$@" ); }

# --- Content consumption ---
# Usage: pbpaste | wisdom
# Usage: cat article.txt | wisdom
alias wisdom='fabric -p extract_wisdom -s'

# Usage: pbpaste | summarize
alias summarize='fabric -p summarize -s'

# Usage: pbpaste | paper
alias paper='fabric -p summarize_paper -s'

# --- Writing assistance ---
# Usage: pbpaste | improve
alias improve='fabric -p improve_writing -s'

# --- Developer workflow ---
# Usage: git diff --staged | git-cmsg
alias git-cmsg='fabric -p create_git_diff_commit -s'

# Usage: git diff main...HEAD | git-summary
alias git-summary='fabric -p summarize_git_changes -s'

# --- Critical thinking / analysis ---
# Usage: pbpaste | fallacies
alias fallacies='fabric -p find_logical_fallacies -s'

# Usage: pbpaste | ideas
alias ideas='fabric -p extract_ideas -s'
