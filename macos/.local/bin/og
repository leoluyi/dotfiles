#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: ${0##*/}

Organize markdown notes from the vault inbox into tag-named folders.
Each note's first \`tags:\` value becomes its destination subfolder.

  Vault:  \$HOME/_notes-vault
  Source: inbox/
  Dest:   notes/<tag>/

Options:
  -h, --help    Show this help and exit
EOF
}

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
esac

# Directory containing markdown files
VAULT_DIR="$HOME/_notes-vault"
SOURCE_DIR="inbox"
DEST_DIR="notes"

if [ ! -d "$VAULT_DIR/$SOURCE_DIR" ]; then
  echo "Error: source directory '$VAULT_DIR/$SOURCE_DIR' does not exist." >&2
  exit 1
fi

# Iterate through all markdown files in the source directory
find "$VAULT_DIR/$SOURCE_DIR" -type f -name "*.md" | while read -r file; do
  echo "Processing $file"

  # Extract the tag from the file. This assumes the tag is on the line immediately following "tags:"
  tag=$(awk '/tags:/{getline; print; exit}' "$file" | sed -e 's/^ *- *//' -e 's/^ *//;s/ *$//')

  echo "Found tag $tag"

  # If a tag is found, proceed with moving the file
  if [ -n "$tag" ]; then
    # Create the target directory if it doesn't exist
    TARGET_DIR="$VAULT_DIR/$DEST_DIR/$tag"
    mkdir -p "$TARGET_DIR"

    # Move the file to the target directory
    mv "$file" "$TARGET_DIR/"
    echo "Moved $file to $TARGET_DIR"
  else
    echo "No tag found for $file"
  fi

done

echo "Done 🪷"
