// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "prettier": {
    "allowed": true
  },
  "relative_line_numbers": "wrapped",
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "base_keymap": "SublimeText",
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "cursor_blink": false,
  "vim_mode": true,
  "restore_on_startup": "empty_tab",
  }
}
