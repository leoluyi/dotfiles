# vim: ft=sh:
# shellcheck shell=bash
# AI shell integrations via llm CLI (https://llm.datasette.io/)

command -v llm >/dev/null || return 0

LLM_MODEL="claude-sonnet-4.6"
_LLM_CMD_SYSTEM="Output only a single bash command with no explanation, no markdown, and no backticks. The command must run on $(uname -s)."

# Print model setup instructions when the configured model is unavailable.
_llm_model_hint() {
    cat >&2 <<EOF
Model '${LLM_MODEL}' not found. Install a plugin and set an API key, e.g.:
  llm install llm-anthropic && llm keys set anthropic   # Claude
  llm install llm-gemini    && llm keys set gemini      # Gemini
  llm install llm-openai    && llm keys set openai      # OpenAI
  llm models                                            # list available models
  llm aliases set default <model>                       # change default model
  https://github.com/simonw/llm
EOF
}

# Wrapper around llm that prints setup instructions on 'Unknown model' errors.
# Passes stdin and all args through transparently; only stderr is intercepted.
_llm() {
    local tmp_err rc
    tmp_err=$(mktemp)
    llm "$@" 2>"$tmp_err"
    rc=$?
    if [ $rc -ne 0 ] && grep -q "Unknown model" "$tmp_err" 2>/dev/null; then
        cat "$tmp_err" >&2
        _llm_model_hint
    else
        cat "$tmp_err" >&2
    fi
    rm -f "$tmp_err"
    return $rc
}

# Generate a shell command from a natural-language description.
# Usage: llm-cmd "list all files modified in the last 24 hours"
llm-cmd() {
    if [ -z "$1" ]; then
        echo "Usage: llm-cmd <natural language description>" >&2
        return 1
    fi
    _llm -m "${LLM_MODEL}" \
        --system "${_LLM_CMD_SYSTEM}" \
        "$*"
}

# Explain a command or piped content.
# Usage: llm-explain "find . -name '*.py' -exec grep foo {} +"
# Usage: some-command 2>&1 | llm-explain
llm-explain() {
    local input
    if [ -t 0 ]; then
        if [ -z "$1" ]; then
            echo "Usage: llm-explain <command>  OR  <cmd> | llm-explain" >&2
            return 1
        fi
        input="$*"
    else
        input="$(cat)"
        [ -n "$1" ] && input="Command: $* -- Output: $input"
    fi
    _llm -m "${LLM_MODEL}" \
        --system "You are a concise shell expert. Explain the following bash command or output clearly and briefly." \
        "$input"
}

# Pipe a failing command's output for a fix suggestion.
# Usage: some-command 2>&1 | llm-fix
llm-fix() {
    local input
    if [ -t 0 ]; then
        echo "Usage: <failing-command> 2>&1 | llm-fix" >&2
        return 1
    fi
    input="$(cat)"
    _llm -m "${LLM_MODEL}" \
        --system "You are a concise shell expert. Given this error output, provide the corrected bash command or a brief fix. Output only the fix, no extra explanation." \
        "$input"
}

# Generate a commit message from staged changes.
# Usage: git-msg
git-msg() {
    local diff
    diff=$(git diff --cached)
    if [ -z "$diff" ]; then
        echo "No staged changes. Run \`git add\` first." >&2
        return 1
    fi
    echo "$diff" | _llm -m "${LLM_MODEL}" \
        --system "You are an expert at writing git commit messages. Output only a single conventional commit message (type: subject, optional body). No markdown, no backticks, no extra explanation." \
        "Write a commit message for this diff:"
}

# Generate a commit message and optionally commit.
# Usage: git-commit-ai
git-commit-ai() {
    local diff msg confirm
    diff=$(git diff --cached)
    if [ -z "$diff" ]; then
        echo "No staged changes. Run \`git add\` first." >&2
        return 1
    fi
    msg=$(echo "$diff" | _llm -m "${LLM_MODEL}" \
        --system "You are an expert at writing git commit messages. Output only a single conventional commit message (type: subject, optional body). No markdown, no backticks, no extra explanation." \
        "Write a commit message for this diff:")
    [ -z "$msg" ] && return 1
    echo "Proposed: $msg"
    read -r -p "Use this message? [y/N] " confirm
    [[ $confirm == [yY] ]] && git commit -m "$msg"
}

# Alt+a: replace current readline line (treated as natural language) with a
# generated bash command. Runs silently; leaves original text on failure.
_llm_inline_suggest() {
    [ -z "$READLINE_LINE" ] && return
    local suggestion
    suggestion=$(llm -m "${LLM_MODEL}" \
        --system "${_LLM_CMD_SYSTEM}" \
        "$READLINE_LINE" 2>/dev/null)
    if [ -n "$suggestion" ]; then
        READLINE_LINE="$suggestion"
        READLINE_POINT=${#READLINE_LINE}
    fi
}
# Only bind in interactive shells — readline is not available in non-interactive contexts.
[[ $- == *i* ]] && bind -x '"\ea": _llm_inline_suggest'
