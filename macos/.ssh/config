# Local, machine-specific overrides (gitignored).
# Must stay at the top, before any Host blocks. Missing file is non-fatal.
Include ~/.ssh/config.local

# Default Github
Host github.com
HostName github.com
User git
IdentityFile ~/.ssh/id_rsa

Host *
