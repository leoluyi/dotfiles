" Turn on Color Syntax Highlighting 
syntax on
filetype off

colorscheme default

" Backspace
"http://stackoverflow.com/questions/11560201/backspace-key-not-working-in-vim-vi
set backspace=indent,eol,start

set autoindent
set textwidth=80

" Spaces are better than a tab character
set expandtab
set smarttab
set tabstop=2
set softtabstop=2
set shiftwidth=2

" line number, use "set nonumber" to take off
set number

" Necesary  for lots of cool vim things
set nocompatible

set ruler
set encoding=utf-8
set fileencoding=utf-8

" Mouse scroll
"set mouse=a

" Finding files
" Display all matchng files when using :find tab autocompletion
set wildmenu
set autoread

" Statusline ------------------------------------------------------------------
" https://shapeshed.com/vim-statuslines/
function! GitBranch()
  if has('git')
    return system("git rev-parse --abbrev-ref HEAD 2>/dev/null | tr -d '\n'")
  else
    return ''
  endif
endfunction

function! StatuslineGit()
  let l:branchname = GitBranch()
  return strlen(l:branchname) > 0?' '.l:branchname.'  ':''
endfunction

function IsBinary()
	if (&binary == 0)
		return ""
	else
		return "[Binary]"
	endif
endfunction

function FileSize()
  " https://magiclen.org/vimrc/
	let bytes = getfsize(expand("%:p"))
	if bytes <= 0
		return "[Empty]"
	endif
	if bytes < 1024
		return "[" . bytes . "B]"
	elseif bytes < 1048576
		return "[" . (bytes / 1024) . "KB]"
	else
		return "[" . (bytes / 1048576) . "MB]"
	endif
endfunction

function! Filename()
  return expand('%:~:.') !=# '' ? expand('%:~:.') : '[No Name]'
endfunction

hi NormalColor guifg=Black guibg=LightGreen ctermbg=46 ctermfg=0
hi InsertColor guifg=Black guibg=Cyan ctermbg=51 ctermfg=0
hi ReplaceColor guifg=Black guibg=maroon1 ctermbg=165 ctermfg=0
hi VisualColor guifg=Black guibg=Orange ctermbg=202 ctermfg=0

" Ensure that the status bar is enabled
set laststatus=2

set statusline=
set statusline+=%#NormalColor#%{(mode()=='n')?'\ \ NORMAL\ ':''}
set statusline+=%#InsertColor#%{(mode()=='i')?'\ \ INSERT\ ':''}
set statusline+=%#ReplaceColor#%{(mode()=='R')?'\ \ REPLACE\ ':''}
set statusline+=%#VisualColor#%{(mode()=='v')?'\ \ VISUAL\ ':''}
set statusline+=%#CursorColumn#
set statusline+=%{&paste?'[PASTE]':''}
set statusline+=%{StatuslineGit()}
set statusline+=\ %#TabLineSel#
set statusline+=\ %{Filename()}
set statusline+=\ %m              " Modified
set statusline+=\ %{FileSize()}%{IsBinary()}  " File size
set statusline+=%=                " Split
set statusline+=%#CursorColumn#
set statusline+=\ %{&fileformat}  " File format
set statusline+=\ \|\ %{&fileencoding?&fileencoding:&encoding}  " Encoding
set statusline+=\ \|\ %{strlen(&filetype)?&filetype:'plain'}    " Filetype
set statusline+=\ \ %#PmenuSel#
set statusline+=\ \ %p%%          " Percentage through
set statusline+=\ \|\ %l:%c       " Line number:Column number
set statusline+=\ %#LineNr#
set statusline+=\ ✔
